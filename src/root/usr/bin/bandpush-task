#!/bin/sh

LOCK=/tmp/bandpush.lock
[ -f "$LOCK" ] && exit 0
touch "$LOCK"

. /lib/functions.sh
config_load bandpush
config_get enabled config enabled 0

[ "$enabled" != "1" ] && {
    rm -f "$LOCK"
    exit 0
}

lua -e "
local b = require('luci.bandpush')
local p = require('luci.push')
local r = b.generate_report()
local a = b.check_threshold()
if a then r = r .. '\n\n' .. a end
p.send(r)
"

rm -f "$LOCK"
